# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=resolveiq

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Email (SendGrid)
SENDGRID_API_KEY=your-key-here
EMAIL_FROM=noreply@resolveiq.com

# App
APP_BASE_URL=http://localhost:3000
PORT=3000

# AI
ANTHROPIC_API_KEY=your-key-here

# Escalation timing (minutes)
ESCALATION_REMINDER_MINUTES=60
ESCALATION_REROUTE_MINUTES=180
ESCALATION_CRITICAL_MINUTES=360
