# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=resolveiq
DB_POOL_SIZE=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_SSL=false
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-here
JWT_EXPIRES_IN=7d

# Email (SendGrid — leave blank to use SMTP)
SENDGRID_API_KEY=
EMAIL_FROM=your.gmail@gmail.com

# SMTP / Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# App
APP_BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
ENABLE_SWAGGER=true

# AI
ANTHROPIC_API_KEY=your-key-here

# AI (Groq)
GROQ_API_KEY=your-groq-api-key

# Seed passwords (used by npm run seed)
SEED_ADMIN_PASSWORD=Admin@123
SEED_DEFAULT_PASSWORD=Welcome@123

# Cloudinary (file attachments)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Escalation timing (minutes)
ESCALATION_REMINDER_MINUTES=60
ESCALATION_REROUTE_MINUTES=180
ESCALATION_CRITICAL_MINUTES=360
